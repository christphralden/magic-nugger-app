# Database superuser
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=magic_nugger
POSTGRES_HOST=localhost

# Database app user
APP_USER=
APP_USER_PASSWORD=

# Database read only user
APP_RO_USER=
APP_RO_PASSWORD=

# pg_partman maintenance role
PARTMAN_PASSWORD=

# Constructed by docker-compose for containerized runs. For local dev, set manually.
# postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL=postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/magic_nugger

# Session — generate with: openssl rand -base64 32
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=3000
NODE_ENV=development
ENVIRONMENT=local
CORS_ORIGIN=http://localhost:5173
RPM_LIMIT=3000
# Internal secret used for diagnostics 
INTERNAL_SECRET= 

# DB Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DB_SSL_MODE=prefer

# Web App
VITE_WEB_SERVER_URL=http://localhost:3000
VITE_API_URL=api/v1
