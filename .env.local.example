# Database superuser
POSTGRES_USER=<CHANGE_ME>
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=magic_nugger
POSTGRES_HOST=localhost

# Database app user
APP_USER=<CHANGE_ME>
APP_USER_PASSWORD=<CHANGE_ME>

# Database read only user
APP_RO_USER=<CHANGE_ME>
APP_RO_PASSWORD=<CHANGE_ME>

# Constructed by docker-compose for containerized runs. For local dev, set manually.
# postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL=postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/magic_nugger

# Session — generate with: openssl rand -base64 32
SESSION_SECRET=<CHANGE_ME>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=3000
NODE_ENV=development
ENVIRONMENT=local
CORS_ORIGIN=http://localhost:5173
RPS_LIMIT=45

# DB Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DB_SSL_MODE=prefer

# Web App
VITE_WEB_SERVER_URL=http://localhost:3000
VITE_API_URL=api/v1
