{
  "name": "magic-nugger-app",
  "private": true,
  "workspaces": [
    "web-server",
    "web-app",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "node --env-file=.env.local db/runner.mjs up",
    "db:rollback": "node --env-file=.env.local db/runner.mjs down",
    "db:backup": "bash db/backup.sh",
    "db:restore": "bash db/restore.sh"
  },
  "overrides": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "pg": "^8.11.5"
  }
}
