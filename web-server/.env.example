# Constructed by docker-compose for containerized runs. For local dev, set manually.
# postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL=postgresql://app:app@localhost:5432/magic_nugger

# Session
SESSION_SECRET=change_me_in_production

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=3000
NODE_ENV=development
ENVIRONMENT=local
CORS_ORIGIN=http://localhost:5173
RPM_LIMIT=3000
GAME_SESSION_RESUME_WINDOW_MS=1800000

# Internal secret used for diagnostics 
INTERNAL_SECRET= 

# DB Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DB_SSL_MODE=prefer
