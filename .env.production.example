# Database superuser
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=magic_nugger
POSTGRES_HOST=magic-nugger-postgres

# Database app user
APP_USER=
APP_USER_PASSWORD=

# Database read only user
APP_RO_USER=
APP_RO_PASSWORD=

# DATABASE_URL is not set here — docker-compose constructs it from APP_USER, APP_USER_PASSWORD, POSTGRES_DB

# Session
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com
RPM_LIMIT=3000

# DB Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DB_SSL_MODE=prefer
