# Database superuser
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=magic_nugger

# Database app user
APP_USER=app
APP_USER_PASSWORD=app_password

# Database read only user
APP_RO_USER=jas
APP_RO_PASSWORD=jas

# Constructed by docker-compose for containerized runs. For local dev, set manually.
# postgresql://<APP_USER>:<APP_USER_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL=postgresql://app:app_password@localhost:5432/magic_nugger

# Session
SESSION_SECRET=change_me_in_production

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=3000
NODE_ENV=development
ENVIRONMENT=local
CORS_ORIGIN=http://localhost:5173
RPS_LIMIT=45

# DB Pool
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000
DB_SSL_MODE=prefer

# Web App
VITE_WEB_SERVER_URL=http://localhost:3000
VITE_API_URL=api/v1
